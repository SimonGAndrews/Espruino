# Disable task watchdogs (prevent resets in QEMU)
CONFIG_ESP_TASK_WDT=n
CONFIG_ESP_INTERRUPT_WDT=n

# Disable WiFi and coexistence (QEMU does not emulate WiFi/BT fully)
CONFIG_ESP32_WIFI_ENABLED=n
CONFIG_ESP32_ENABLE_COEXISTENCE=n
CONFIG_ESP32_BLUEDROID_ENABLED=n

# Disable invalid GPIO pullups (prevents gpio_pullup_en errors)
CONFIG_ESP32_GPIO_PULLUP_CHECK=n

# Optional: reduce JS memory if needed to avoid memset crash
CONFIG_ESPRUINO_MEM_SIZE=65536

# Optional: disable trace facility (less critical for QEMU)
CONFIG_FREERTOS_USE_TRACE_FACILITY=n
